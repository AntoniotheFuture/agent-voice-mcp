{
  "name": "agent-voice",
  "version": "0.0.5",
  "description": "本地MCP服务，为开发Agent提供TTS语音播报能力",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agent-voice": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "node --import tsx --test --test-concurrency=1 tests/cloud.test.ts tests/index.test.ts tests/piper.test.ts",
    "debug": "node --import tsx scripts/debug.ts",
    "debug-cloud": "node --import tsx scripts/debug-cloud.ts"
  },
  "keywords": [
    "mcp",
    "tts",
    "voice",
    "speech",
    "mcp-server",
    "agent",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-username/agent-voice.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/agent-voice/issues"
  },
  "homepage": "https://github.com/your-username/agent-voice#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
